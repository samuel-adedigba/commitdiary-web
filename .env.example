NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
# Server-only API origin. Browser requests remain same-origin through middleware.
API_URL=https://api.commitdiary.dev
# Public origins for host-aware routing. Include the scheme and omit trailing paths.
NEXT_PUBLIC_MARKETING_URL=https://commitdiary.dev
NEXT_PUBLIC_APP_URL=https://app.commitdiary.dev
# Public destinations used by landing-page links and metadata.
NEXT_PUBLIC_GITHUB_URL=https://github.com/samuel-adedigba/Commit-Diary-Vscode-Extension
NEXT_PUBLIC_MARKETPLACE_URL=https://marketplace.visualstudio.com/items?itemName=samuel-adedigba.commitdiary-extension
NEXT_PUBLIC_STEPPER_URL=https://github.com/samuel-adedigba/ai-inference-stepper
NEXT_PUBLIC_DOCS_URL=https://app.commitdiary.dev/documentation
NEXT_PUBLIC_DISCORD_DOCS_URL=https://github.com/samuel-adedigba/Commit-Diary-Vscode-Extension/blob/main/DISCORD_WEBHOOKS_SETUP.md
