{
  "name": "@commitdiary/web-dashboard",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "author": {
    "name": "CommitDiary Team",
    "url": "https://github.com/samuel-adedigba/Commit-Diary-Vscode-Extension"
  },
  "keywords": [
    "react",
    "javascript",
    "commitdiary",
    "nextjs",
    "nextjs13",
    "commit-tracker",
    "developer-tools",
    "git-analytics"
  ],
  "scripts": {
    "dev": "cross-env NODE_ENV=development next dev",
    "build": "cross-env NODE_ENV=production next build",
    "deploy:preview": "pnpm dlx vercel",
    "deploy:production": "pnpm dlx vercel --prod",
    "start": "cross-env NODE_ENV=production next start",
    "start:prod": "cross-env NODE_ENV=production next start",
    "start:dev": "cross-env NODE_ENV=development next dev",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.81.1",
    "@tanstack/react-table": "^8.10.0",
    "@vercel/analytics": "^1.0.1",
    "bootstrap": "^5.3.1",
    "classnames": "^2.3.2",
    "cross-env": "^7.0.3",
    "next": "15.5.21",
    "react": "19.2.8",
    "react-bootstrap": "^2.8.0",
    "react-copy-to-clipboard": "5.1.1",
    "react-dom": "19.2.8",
    "react-dropzone": "^14.2.3",
    "react-feather": "^2.0.10",
    "react-icons": "^5.2.1",
    "react-responsive": "^9.0.2",
    "react-select": "^5.7.4",
    "sass": "^1.64.2",
    "simplebar": "^6.2.5",
    "simplebar-react": "^3.2.4",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "18.15.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/parser": "8.65.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.21",
    "jsdom": "^29.1.0",
    "typescript": "5.0.3",
    "vitest": "^1.6.1"
  },
  "pnpm": {
    "overrides": {
      "next@15.5.21>postcss": "8.5.10"
    }
  }
}
